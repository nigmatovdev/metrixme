{
  "permissions": {
    "allow": [
      "PowerShell(node -v)",
      "PowerShell(npm -v)",
      "PowerShell(\"---NODE---\")",
      "PowerShell(\"---NPM---\")",
      "PowerShell(npm run build)",
      "WebFetch(domain:metrixme.com)",
